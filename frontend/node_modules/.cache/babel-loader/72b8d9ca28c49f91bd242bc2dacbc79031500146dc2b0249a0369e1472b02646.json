043E\\u0436\\u043D\\u043E\\u0441\\u0442\\u0438 \\u0441\\u0430\\u0439\\u0442\\u0430 \\u2014 \\u043D\\u0443\\u0436\\u043D\\u0430 \\u0440\\u0435\\u0433\\u0438\\u0441\\u0442\\u0440\\u0430\\u0446\\u0438\\u044F. \\u041F\\u0440\\u043E\\u0432\\u0435\\u0440\\u043A\\u0430 \\u0430\\u0434\\u0440\\u0435\\u0441\\u0430 \\u044D\\u043B\\u0435\\u043A\\u0442\\u0440\\u043E\\u043D\\u043D\\u043E\\u0439 \\u043F\\u043E\\u0447\\u0442\\u044B \\u043D\\u0435 \\u043E\\u0441\\u0443\\u0449\\u0435\\u0441\\u0442\\u0432\\u043B\\u044F\\u0435\\u0442\\u0441\\u044F, \\u0432\\u044B \\u043C\\u043E\\u0436\\u0435\\u0442\\u0435 \\u0432\\u0432\\u0435\\u0441\\u0442\\u0438 \\u043B\\u044E\\u0431\\u043E\\u0439 email.\"}),/*#__PURE__*/_jsx(\"p\",{className:styles.textItem,children:\"\\u0417\\u0430\\u0445\\u043E\\u0434\\u0438\\u0442\\u0435 \\u0438 \\u0434\\u0435\\u043B\\u0438\\u0442\\u0435\\u0441\\u044C \\u0441\\u0432\\u043E\\u0438\\u043C\\u0438 \\u043B\\u044E\\u0431\\u0438\\u043C\\u044B\\u043C\\u0438 \\u0440\\u0435\\u0446\\u0435\\u043F\\u0442\\u0430\\u043C\\u0438!\"})]})]}),/*#__PURE__*/_jsxs(\"aside\",{children:[/*#__PURE__*/_jsx(\"h2\",{className:styles.additionalTitle,children:\"\\u0421\\u0441\\u044B\\u043B\\u043A\\u0438\"}),/*#__PURE__*/_jsxs(\"div\",{className:styles.text,children:[/*#__PURE__*/_jsxs(\"p\",{className:styles.textItem,children:[\"\\u041A\\u043E\\u0434 \\u043F\\u0440\\u043E\\u0435\\u043A\\u0442\\u0430 \\u043D\\u0430\\u0445\\u043E\\u0434\\u0438\\u0442\\u0441\\u044F \\u0442\\u0443\\u0442 - \",/*#__PURE__*/_jsx(\"a\",{href:\"#\",className:styles.textLink,children:\"Github\"})]}),/*#__PURE__*/_jsxs(\"p\",{className:styles.textItem,children:[\"\\u0410\\u0432\\u0442\\u043E\\u0440 \\u043F\\u0440\\u043E\\u0435\\u043A\\u0442\\u0430: \",/*#__PURE__*/_jsx(\"a\",{href:\"#\",className:styles.textLink,children:\"\\u0418\\u043C\\u044F \\u0410\\u0432\\u0442\\u043E\\u0440\\u0430\"})]})]})]})]})]})]});};export default About;","map":{"version":3,"names":["Title","Container","Main","styles","MetaTags","jsx","_jsx","jsxs","_jsxs","About","_ref","updateOrders","orders","children","name","content","property","className","title","subtitle","text","textItem","additionalTitle","href","textLink"],"sources":["/frontend/src/pages/about/index.js"],"sourcesContent":["import { Title, Container, Main } from '../../components'\nimport styles from './styles.module.css'\nimport MetaTags from 'react-meta-tags'\n\nconst About = ({ updateOrders, orders }) => {\n  \n  return <Main>\n    <MetaTags>\n      <title>О проекте</title>\n      <meta name=\"description\" content=\"Фудграм - О проекте\" />\n      <meta property=\"og:title\" content=\"О проекте\" />\n    </MetaTags>\n    \n    <Container>\n      <h1 className={styles.title}>Привет!</h1>\n      <div className={styles.content}>\n        <div>\n          <h2 className={styles.subtitle}>Что это за сайт?</h2>\n          <div className={styles.text}>\n            <p className={styles.textItem}>\n              Представляю вам проект, созданный во время обучения в Яндекс Практикуме. Этот проект — часть учебного курса, но он создан полностью самостоятельно.\n            </p>\n            <p className={styles.textItem}>\n              Цель этого сайта — дать возможность пользователям создавать и хранить рецепты на онлайн-платформе. Кроме того, можно скачать список продуктов, необходимых для\n              приготовления блюда, просмотреть рецепты друзей и добавить любимые рецепты в список избранных.\n            </p>\n            <p className={styles.textItem}>\n              Чтобы использовать все возможности сайта — нужна регистрация. Проверка адреса электронной почты не осуществляется, вы можете ввести любой email. \n            </p>\n            <p className={styles.textItem}>\n              Заходите и делитесь своими любимыми рецептами!\n            </p>\n          </div>\n        </div>\n        <aside>\n          <h2 className={styles.additionalTitle}>\n            Ссылки\n          </h2>\n          <div className={styles.text}>\n            <p className={styles.textItem}>\n              Код проекта находится тут - <a href=\"#\" className={styles.textLink}>Github</a>\n            </p>\n            <p className={styles.textItem}>\n              Автор проекта: <a href=\"#\" className={styles.textLink}>Имя Автора</a>\n            </p>\n          </div>\n        </aside>\n      </div>\n      \n    </Container>\n  </Main>\n}\n\nexport default About\n"],"mappings":"AAAA,OAASA,KAAK,CAAEC,SAAS,CAAEC,IAAI,KAAQ,kBAAkB,CACzD,MAAO,CAAAC,MAAM,KAAM,qBAAqB,CACxC,MAAO,CAAAC,QAAQ,KAAM,iBAAiB,QAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAEtC,KAAM,CAAAC,KAAK,CAAGC,IAAA,EAA8B,IAA7B,CAAEC,YAAY,CAAEC,MAAO,CAAC,CAAAF,IAAA,CAErC,mBAAOF,KAAA,CAACN,IAAI,EAAAW,QAAA,eACVL,KAAA,CAACJ,QAAQ,EAAAS,QAAA,eACPP,IAAA,UAAAO,QAAA,CAAO,mDAAS,CAAO,CAAC,cACxBP,IAAA,SAAMQ,IAAI,CAAC,aAAa,CAACC,OAAO,CAAC,gGAAqB,CAAE,CAAC,cACzDT,IAAA,SAAMU,QAAQ,CAAC,UAAU,CAACD,OAAO,CAAC,mDAAW,CAAE,CAAC,EACxC,CAAC,cAEXP,KAAA,CAACP,SAAS,EAAAY,QAAA,eACRP,IAAA,OAAIW,SAAS,CAAEd,MAAM,CAACe,KAAM,CAAAL,QAAA,CAAC,uCAAO,CAAI,CAAC,cACzCL,KAAA,QAAKS,SAAS,CAAEd,MAAM,CAACY,OAAQ,CAAAF,QAAA,eAC7BL,KAAA,QAAAK,QAAA,eACEP,IAAA,OAAIW,SAAS,CAAEd,MAAM,CAACgB,QAAS,CAAAN,QAAA,CAAC,8EAAgB,CAAI,CAAC,cACrDL,KAAA,QAAKS,SAAS,CAAEd,MAAM,CAACiB,IAAK,CAAAP,QAAA,eAC1BP,IAAA,MAAGW,SAAS,CAAEd,MAAM,CAACkB,QAAS,CAAAR,QAAA,CAAC,4vBAE/B,CAAG,CAAC,cACJP,IAAA,MAAGW,SAAS,CAAEd,MAAM,CAACkB,QAAS,CAAAR,QAAA,CAAC,kzCAG/B,CAAG,CAAC,cACJP,IAAA,MAAGW,SAAS,CAAEd,MAAM,CAACkB,QAAS,CAAAR,QAAA,CAAC,guBAE/B,CAAG,CAAC,cACJP,IAAA,MAAGW,SAAS,CAAEd,MAAM,CAACkB,QAAS,CAAAR,QAAA,CAAC,wPAE/B,CAAG,CAAC,EACD,CAAC,EACH,CAAC,cACNL,KAAA,UAAAK,QAAA,eACEP,IAAA,OAAIW,SAAS,CAAEd,MAAM,CAACmB,eAAgB,CAAAT,QAAA,CAAC,sCAEvC,CAAI,CAAC,cACLL,KAAA,QAAKS,SAAS,CAAEd,MAAM,CAACiB,IAAK,CAAAP,QAAA,eAC1BL,KAAA,MAAGS,SAAS,CAAEd,MAAM,CAACkB,QAAS,CAAAR,QAAA,EAAC,4IACD,cAAAP,IAAA,MAAGiB,IAAI,CAAC,GAAG,CAACN,SAAS,CAAEd,MAAM,CAACqB,QAAS,CAAAX,QAAA,CAAC,QAAM,CAAG,CAAC,EAC7E,CAAC,cACJL,KAAA,MAAGS,SAAS,CAAEd,MAAM,CAACkB,QAAS,CAAAR,QAAA,EAAC,6EACd,cAAAP,IAAA,